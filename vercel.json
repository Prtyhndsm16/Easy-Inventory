{
  "buildCommand": "cp database/database.sqlite /tmp/ && npm run build",
  "outputDirectory": "public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.php" }
  ],
  "env": {
    "APP_NAME": "Easy Inventory Manager",
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "APP_URL": "https://easy-inventory-manager.vercel.app",
    "DB_CONNECTION": "sqlite",
    "DB_DATABASE": "/tmp/database.sqlite",
    "SESSION_DRIVER": "file",
    "CACHE_DRIVER": "file",
    "QUEUE_CONNECTION": "sync"
  }
}
